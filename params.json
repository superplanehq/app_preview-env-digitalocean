{
  "install_params": [
    {
      "name": "repository",
      "label": "GitHub Repository",
      "type": "integration-resource",
      "integration": "github",
      "resourceType": "repository",
      "description": "Repository to watch for pull requests",
      "required": true
    },
    {
      "name": "ssh_secret",
      "label": "SSH Secret",
      "type": "secret_picker",
      "description": "Secret containing the SSH private key for accessing droplets. The key name should be 'private_key'.",
      "required": true
    },
    {
      "name": "region",
      "label": "Droplet Region",
      "type": "integration-resource",
      "integration": "digitalocean",
      "resourceType": "region",
      "default": "nyc1",
      "description": "DigitalOcean region for preview droplets",
      "required": false
    },
    {
      "name": "size",
      "label": "Droplet Size",
      "type": "integration-resource",
      "integration": "digitalocean",
      "resourceType": "size",
      "default": "s-1vcpu-1gb",
      "description": "DigitalOcean droplet size",
      "required": false
    },
    {
      "name": "image",
      "label": "Droplet Image",
      "type": "integration-resource",
      "integration": "digitalocean",
      "resourceType": "image",
      "default": "ubuntu-24-04-x64",
      "description": "DigitalOcean droplet image",
      "required": false
    }
  ]
}